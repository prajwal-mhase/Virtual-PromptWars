generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  ADMIN
  MANAGER
  VOLUNTEER
  VENDOR
  VISITOR
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ESCALATED
}

enum TicketStatus {
  ISSUED
  SCANNED
  EXCEPTION
  REFUNDED
}

model Role {
  id    String   @id @default(cuid())
  name  RoleName @unique
  users User[]
}

model User {
  id           String           @id @default(cuid())
  name         String
  email        String           @unique
  passwordHash String
  roleId       String
  role         Role             @relation(fields: [roleId], references: [id])
  avatarUrl    String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  sessions     Session[]
  tickets      Ticket[]
  conversations AIConversation[]
  notifications Notification[]
  volunteer    Volunteer?
  vendorUser   FoodVendor?
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  refreshHash  String
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model Stadium {
  id        String      @id @default(cuid())
  name      String
  city      String
  country   String
  capacity  Int
  latitude  Float
  longitude Float
  zones     CrowdZone[]
  gates     Gate[]
  parking   ParkingLot[]
  matches   Match[]
  vendors   FoodVendor[]
  equipment Equipment[]
}

model Match {
  id        String   @id @default(cuid())
  stadiumId String
  stadium  Stadium  @relation(fields: [stadiumId], references: [id])
  homeTeam String
  awayTeam String
  kickoff  DateTime
  tickets  Ticket[]
}

model Gate {
  id        String  @id @default(cuid())
  stadiumId String
  stadium  Stadium @relation(fields: [stadiumId], references: [id])
  name      String
  latitude  Float
  longitude Float
}

model Ticket {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  matchId   String
  match     Match        @relation(fields: [matchId], references: [id])
  section   String
  row       String
  seat      String
  qrCode    String       @unique
  status    TicketStatus @default(ISSUED)
  scannedAt DateTime?
}

model Incident {
  id           String         @id @default(cuid())
  title        String
  description  String
  location     String
  severity     Severity
  status       IncidentStatus @default(OPEN)
  assignedTeam String
  timeline     IncidentEvent[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model IncidentEvent {
  id         String   @id @default(cuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  message    String
  createdAt  DateTime @default(now())
}

model CrowdZone {
  id               String   @id @default(cuid())
  stadiumId        String
  stadium          Stadium  @relation(fields: [stadiumId], references: [id])
  name             String
  density          Int
  predictedDensity Int
  congestionRisk   Severity
  x                Float
  y                Float
  updatedAt        DateTime @updatedAt
}

model ParkingLot {
  id             String  @id @default(cuid())
  stadiumId      String
  stadium        Stadium @relation(fields: [stadiumId], references: [id])
  name           String
  capacity       Int
  occupancy      Int
  walkingMinutes Int
  latitude       Float
  longitude      Float
}

model FoodVendor {
  id           String  @id @default(cuid())
  stadiumId    String
  stadium      Stadium @relation(fields: [stadiumId], references: [id])
  ownerId      String?
  owner        User?   @relation(fields: [ownerId], references: [id])
  name         String
  cuisine      String
  queueMinutes Int
  inventory    Json
  sales        Order[]
}

model Order {
  id        String     @id @default(cuid())
  vendorId  String
  vendor    FoodVendor @relation(fields: [vendorId], references: [id])
  total     Decimal
  items     Json
  createdAt DateTime   @default(now())
}

model Volunteer {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  shiftStart  DateTime
  shiftEnd    DateTime
  attendance  Boolean  @default(false)
  tasks       Task[]
}

model Task {
  id          String    @id @default(cuid())
  volunteerId String?
  volunteer   Volunteer? @relation(fields: [volunteerId], references: [id])
  title       String
  status      String
  priority    Severity
  dueAt       DateTime
}

model Equipment {
  id                String   @id @default(cuid())
  stadiumId         String
  stadium           Stadium  @relation(fields: [stadiumId], references: [id])
  name              String
  category          String
  healthScore       Int
  failureRisk       Severity
  nextMaintenanceAt DateTime
}

model SustainabilityMetric {
  id        String   @id @default(cuid())
  stadiumId String
  key       String
  value     Float
  unit      String
  recordedAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AIConversation {
  id        String      @id @default(cuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  language  String      @default("en")
  messages  AIMessage[]
  createdAt DateTime    @default(now())
}

model AIMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  createdAt      DateTime       @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  metadata  Json
  createdAt DateTime @default(now())
}
